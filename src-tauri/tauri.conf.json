{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Garmin Run Dashboard",
  "version": "0.1.0",
  "identifier": "com.kimkihong.garmin-run-dashboard",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Garmin Run Dashboard",
        "width": 1480,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
